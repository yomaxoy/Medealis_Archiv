# =============================================================================
# Medealis Warehouse Management System - Environment Configuration
# =============================================================================
# Kopieren Sie diese Datei zu ".env" und tragen Sie Ihre Werte ein
# MIGRIERT: PostgreSQL + SharePoint Storage
# =============================================================================

# =============================================================================
# PostgreSQL Database (NEU - ERFORDERLICH)
# =============================================================================
POSTGRES_DB=medealis
POSTGRES_USER=medealis_user
POSTGRES_PASSWORD=BITTE_AENDERN_sichere_passw0rt_hier

# =============================================================================
# AI API Keys (erforderlich für AI-Features)
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# Document Storage Configuration
# =============================================================================
# Primär: SharePoint für Dokumente (empfohlen für Azure/Cloud)
USE_SERVER_STORAGE=false
USE_SHAREPOINT=false

# SharePoint Credentials (nur wenn USE_SHAREPOINT=true)
SHAREPOINT_SITE_URL=https://yourcompany.sharepoint.com/sites/YourSite
SHAREPOINT_CLIENT_ID=your_azure_app_client_id
SHAREPOINT_CLIENT_SECRET=your_azure_app_client_secret
SHAREPOINT_TENANT_ID=your_azure_tenant_id

# Lokale Pfade (für User-Dateien)
USER_DATA_DIR=./user_data

# =============================================================================
# Application Environment
# =============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
