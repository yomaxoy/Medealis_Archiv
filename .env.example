# =============================================================================
# Medealis Warehouse Management System - Environment Configuration
# =============================================================================
# Kopieren Sie diese Datei zu ".env" und tragen Sie Ihre Werte ein
# =============================================================================

# API Keys (erforderlich für AI-Features)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Storage Configuration
USE_SERVER_STORAGE=true

# Pfade (für Docker - Windows-Pfade mit \\ oder / verwenden)
# Beispiel Windows: DATABASE_PATH=C:/Medealis/database
# Beispiel Linux: DATABASE_PATH=/mnt/nas/medealis/database
DATABASE_PATH=./database
USER_DATA_DIR=./user_data

# Umgebung
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
