# =============================================================================
# Medealis Warehouse Management System - Environment Configuration
# =============================================================================
# Kopieren Sie diese Datei zu ".env" und tragen Sie Ihre Werte ein
# =============================================================================

# =============================================================================
# AI Service Konfiguration
# =============================================================================
# Aktiver KI-Provider: claude (Standard), openai, ollama
AI_PROVIDER=claude

# Claude / Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_TIMEOUT=60.0
CLAUDE_MAX_RETRIES=2

# OpenAI (optional, fuer spaetere Nutzung)
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=

# Ollama (optional, fuer lokale Modelle)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# =============================================================================
# Document Storage Configuration
# =============================================================================
# GETRENNTE Steuerung für Datenbank und Dokumente

# Datenbank-Speicherort (Server/NAS vs. Lokal)
USE_SERVER_STORAGE_DB=true

# Dokumente-Speicherort (Server/NAS vs. Lokal)
USE_SERVER_STORAGE_DOCUMENTS=true

# SharePoint (optional, als Fallback)
USE_SHAREPOINT=false

# SharePoint Credentials (nur wenn USE_SHAREPOINT=true)
SHAREPOINT_SITE_URL=https://yourcompany.sharepoint.com/sites/YourSite
SHAREPOINT_CLIENT_ID=your_azure_app_client_id
SHAREPOINT_CLIENT_SECRET=your_azure_app_client_secret
SHAREPOINT_TENANT_ID=your_azure_tenant_id

# =============================================================================
# Document Auto-Open Configuration
# =============================================================================
# Automatisches Öffnen von Dokumenten nach Generierung (für Druck-Workflow)
AUTO_OPEN_DOCUMENTS=true

# Automatisches Öffnen von Barcode-Dokumenten
AUTO_OPEN_BARCODES=true

# Maximale Anzahl Dateien für Auto-Open (Schutz vor zu vielen Fenstern)
AUTO_OPEN_LIMIT=5

# =============================================================================
# Application Environment
# =============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
