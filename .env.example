# ==========================================
# STORAGE CONFIGURATION (NEU ab Version 2.0)
# ==========================================

# PRIMARY STORAGE: Server (Netzlaufwerk A:\)
# Standard: Server-Speicherung auf Firmenserver (empfohlen für Produktion)
# Der Server muss als Laufwerk A:\ verbunden sein
USE_SERVER_STORAGE=true

# FALLBACK STORAGE: SharePoint (optional)
# SharePoint wird nur als Fallback verwendet, wenn Server-Speicherung fehlschlägt
# Für reine Server-Storage: USE_SHAREPOINT=false
USE_SHAREPOINT=false

# ==========================================
# SHAREPOINT CONFIGURATION (optional)
# ==========================================
# Nur erforderlich wenn SharePoint als Fallback aktiviert ist
SHAREPOINT_SITE_URL=https://yourcompany.sharepoint.com/sites/MedealisWareneingang
SHAREPOINT_CLIENT_ID=your-application-client-id
SHAREPOINT_CLIENT_SECRET=your-client-secret
SHAREPOINT_TENANT_ID=your-directory-tenant-id

# ==========================================
# OTHER SETTINGS
# ==========================================
DEBUG=false